---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ScrollReveal from '../components/ScrollReveal.astro';
import type { Dictionary, Locale } from '../i18n';
import { localizedPath } from '../i18n';

interface Props {
  dict: Dictionary;
  locale: Locale;
  title: string;
  description: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  path: string; // canonical path without locale prefix, e.g. "/" or "/why-quy-nhon"
  hasVietnamese?: boolean; // false when no vi/ translation exists for this page yet
}
const {
  dict,
  locale,
  title,
  description,
  ogImage = '/assets/brand/og-cover.png',
  ogType = 'website',
  path,
  hasVietnamese = true,
} = Astro.props;

const canonicalUrl = new URL(localizedPath(locale, path), Astro.site).toString();
const enUrl = new URL(localizedPath('en', path), Astro.site).toString();
const viUrl = new URL(localizedPath('vi', path), Astro.site).toString();
const ogImageUrl = new URL(ogImage, Astro.site).toString();

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'QNSC — Quy Nhon Semiconductor',
  url: Astro.site?.toString(),
  logo: new URL('/assets/brand/og-cover.png', Astro.site).toString(),
  address: {
    '@type': 'PostalAddress',
    streetAddress: '99 Tay Son Street, Floor 1, Pisico Building',
    addressLocality: 'Quy Nhon Nam Ward',
    addressRegion: 'Gia Lai Province',
    addressCountry: 'VN',
  },
  email: 'contact@qnsc.vn',
};
---

<!doctype html>
<html lang={locale} class="no-js">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="en" href={enUrl} />
    {hasVietnamese && <link rel="alternate" hreflang="vi" href={viUrl} />}
    <link rel="alternate" hreflang="x-default" href={enUrl} />

    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content={locale === 'en' ? 'en_US' : 'vi_VN'} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="icon" type="image/svg+xml" href="/assets/brand/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/assets/brand/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/assets/brand/favicon-16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/assets/brand/apple-touch-icon-180.png" />

    <script type="application/ld+json" is:inline set:html={JSON.stringify(orgSchema)} />
  </head>
  <body>
    <Navbar dict={dict} locale={locale} />
    <slot />
    <Footer dict={dict} locale={locale} />
    <ScrollReveal />
  </body>
</html>
