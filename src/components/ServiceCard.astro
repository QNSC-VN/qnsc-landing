---
import Icon from './Icon.astro';
import Card from './Card.astro';
import Badge from './Badge.astro';

interface Props {
  icon: string;
  title: string;
  description: string;
  tags: string[];
}
const { icon, title, description, tags } = Astro.props;
---

<Card class="service-card">
  <div class="bg-copper/10 text-copper mb-4 flex h-11 w-11 items-center justify-center rounded-xl">
    <Icon path={icon} size={22} />
  </div>
  <h3 class="mb-2 text-lg font-semibold">{title}</h3>
  <p class="text-titanium mb-4 text-[0.95rem] leading-relaxed">{description}</p>
  <div class="flex flex-wrap gap-2">
    {tags.map((tag) => <Badge tone="outline">{tag}</Badge>)}
  </div>
</Card>
