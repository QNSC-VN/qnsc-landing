---
import { getEntry, render } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from './Icon.astro';
import { icons } from '../lib/homepage.astro';
import type { Dictionary, Locale } from '../i18n';
import { localizedPath } from '../i18n';

import heroImg from '../assets/article/quy-nhon-coast.jpg';

interface Props {
  dict: Dictionary;
  locale: Locale;
}
const { dict, locale } = Astro.props;

const article = await getEntry('articles', 'why-quy-nhon');
if (!article) throw new Error('why-quy-nhon article entry missing');
const { Content } = await render(article);
---

<BaseLayout
  dict={dict}
  locale={locale}
  path="/why-quy-nhon"
  title={`${article.data.title} — QNSC`}
  description={article.data.description}
  ogImage={`/assets/article/${article.data.heroImage}`}
  ogType="article"
>
  <header class="relative">
    <Image
      src={heroImg}
      alt="Quy Nhơn, Vietnam — coastal city on the central coast"
      class="absolute inset-0 h-full w-full object-cover"
      loading="eager"
    />
    <div class="from-deep-navy via-deep-navy/70 to-deep-navy/30 absolute inset-0 bg-gradient-to-t">
    </div>
    <div class="relative z-10 mx-auto max-w-[900px] px-6 pt-32 pb-20">
      <a
        href={localizedPath(locale, '/')}
        class="text-titanium hover:text-silicon-white mb-8 inline-flex items-center gap-2 text-sm"
        >← Back to home</a
      >
      <span class="section-label">A Letter from Our Executive Board Advisor</span>
      <h1 class="mt-3 mb-4 text-4xl font-bold text-balance md:text-5xl">{article.data.title}</h1>
      <p class="text-titanium mb-6 text-lg">
        Building the future of semiconductor innovation from the heart of Vietnam
      </p>
      <div class="text-muted-gray text-sm">
        <strong class="text-silicon-white">{article.data.author}</strong><br />
        <span>{article.data.authorRole}</span>
      </div>
    </div>
  </header>

  <main class="article-body py-16">
    <div class="prose mx-auto max-w-[680px] px-6">
      <Content />
      <a
        href={`${localizedPath(locale, '/')}#contact`}
        class="text-copper hover:text-clay mt-10 inline-flex items-center gap-2 font-medium"
      >
        Talk to QNSC
        <Icon path={icons.arrowRight} size={18} />
      </a>
    </div>
  </main>
</BaseLayout>

<style>
  .section-label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-copper);
  }
  .prose :global(p) {
    color: var(--color-titanium);
    line-height: 1.8;
    margin-bottom: 1.25em;
  }
  .prose :global(p:first-of-type) {
    font-size: 1.15rem;
    color: var(--color-silicon-white);
  }
  .prose :global(h2) {
    font-size: 1.5rem;
    font-weight: 600;
    margin: 2em 0 0.75em;
    color: var(--color-silicon-white);
  }
  .prose :global(blockquote) {
    border-left: 3px solid var(--color-copper);
    padding-left: 1.25em;
    margin: 2em 0;
    font-style: italic;
    color: var(--color-silicon-white);
    font-size: 1.1rem;
  }
  .prose :global(blockquote p:last-child) {
    color: var(--color-copper);
    font-style: normal;
    font-size: 0.9rem;
    margin-top: 0.5em;
  }
  .prose :global(ul) {
    list-style: disc;
    padding-left: 1.5em;
    color: var(--color-titanium);
    margin-bottom: 1.25em;
  }
  .prose :global(ul li) {
    margin-bottom: 0.5em;
  }
  .prose :global(li)::marker {
    color: var(--color-copper);
  }
  .prose :global(img) {
    border-radius: 16px;
    width: 100%;
    margin: 2em 0 0.5em;
  }
  .prose :global(figcaption) {
    font-size: 0.85rem;
    color: var(--color-muted-gray);
    text-align: center;
  }
  .prose :global(strong) {
    color: var(--color-silicon-white);
  }
</style>
