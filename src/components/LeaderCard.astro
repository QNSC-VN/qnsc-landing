---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  variant: 'leader' | 'lead-advisor' | 'advisor';
  name: string;
  nameEn?: string;
  role: string;
  photo?: string;
  initials?: string;
  bio?: string;
  bioMission?: string;
  highlights?: string[];
  stats?: Array<{ num: string; unit?: string; label: string }>;
  credLine?: string;
}
const {
  variant,
  name,
  nameEn,
  role,
  photo,
  initials,
  bio,
  bioMission,
  highlights,
  stats,
  credLine,
} = Astro.props;

const images = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/*.jpg', {
  eager: true,
});
const photoSrc = photo ? images[`/src/assets/images/${photo}`]?.default : undefined;

// One avatar treatment everywhere: a real photo if we have one, otherwise a
// copper-tinted initials circle that's styled to look intentional rather
// than like a missing asset. Size is the only thing that varies by tier.
const avatarSize = variant === 'lead-advisor' ? 160 : variant === 'advisor' ? 56 : 72;
---

<div
  class:list={[
    'leader-card reveal rounded-2xl border border-white/10 bg-white/[0.02]',
    variant === 'lead-advisor' ? 'p-8 md:grid md:grid-cols-[160px_1fr] md:gap-8' : 'p-6',
  ]}
>
  <div
    class:list={[
      variant === 'lead-advisor' ? 'mb-6 md:mb-0' : 'mb-4 flex items-start gap-4',
      variant === 'leader' && 'items-center',
    ]}
  >
    {
      photoSrc ? (
        <Image
          src={photoSrc}
          alt={name}
          width={avatarSize}
          height={avatarSize}
          class:list={[
            'flex-shrink-0 rounded-full object-cover',
            variant === 'lead-advisor' && 'aspect-square w-full max-w-[160px] rounded-2xl',
          ]}
          loading="lazy"
        />
      ) : (
        <div
          class="bg-copper/15 text-copper ring-copper/20 flex flex-shrink-0 items-center justify-center rounded-full font-semibold ring-1"
          style={`width: ${avatarSize}px; height: ${avatarSize}px; font-size: ${avatarSize / 2.4}px`}
        >
          {initials}
        </div>
      )
    }

    {
      variant !== 'lead-advisor' && (
        <div class="min-w-0">
          <h3 class="font-semibold">{name}</h3>
          <div class="text-copper text-sm">{role}</div>
        </div>
      )
    }
  </div>

  <div class="min-w-0">
    {
      variant === 'lead-advisor' && (
        <>
          <span class="text-copper font-mono text-xs tracking-widest uppercase">
            Executive Board Advisor
          </span>
          <h3 class="mt-2 text-2xl font-semibold">
            {name} {nameEn && <span class="text-titanium text-lg font-normal">({nameEn})</span>}
          </h3>
          <div class="text-copper mt-1">{role}</div>
        </>
      )
    }

    {bio && <p class="text-titanium mt-3 text-sm leading-relaxed">{bio}</p>}
    {bioMission && <p class="text-silicon-white mt-3 leading-relaxed font-medium">{bioMission}</p>}

    {
      highlights && (
        <ul class="mt-3 space-y-1.5">
          {highlights.map((h) => (
            <li class="text-muted-gray before:text-copper relative pl-4 text-xs before:absolute before:left-0 before:content-['—']">
              {h}
            </li>
          ))}
        </ul>
      )
    }

    {
      stats && (
        <div class="mt-6 grid grid-cols-2 gap-4 sm:grid-cols-4">
          {stats.map((s) => (
            <div>
              <div class="font-mono text-2xl font-semibold tabular-nums">
                {s.num}
                <span class="text-copper">{s.unit}</span>
              </div>
              <div class="text-muted-gray mt-1 text-xs">{s.label}</div>
            </div>
          ))}
        </div>
      )
    }

    {
      credLine && (
        <div class="text-muted-gray mt-6 border-t border-white/10 pt-4 text-sm leading-relaxed whitespace-pre-line">
          {credLine}
        </div>
      )
    }
  </div>
</div>
